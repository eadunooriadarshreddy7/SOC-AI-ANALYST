# Copy this file to .env and fill in your API keys

# Anthropic Claude API Key (required for AI triage)
# Get yours free at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# AbuseIPDB API Key (optional - for IP reputation)
# Free tier: 1000 checks/day at https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=your_abuseipdb_key_here

# VirusTotal API Key (optional - for hash/URL lookup)
# Free tier: 4 lookups/min at https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=your_virustotal_key_here
